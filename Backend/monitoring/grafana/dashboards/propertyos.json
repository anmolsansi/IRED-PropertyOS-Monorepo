{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": { "type": "grafana", "uid": "-- Grafana --" },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "id": null,
  "links": [],
  "panels": [
    {
      "title": "Request Rate (req/s)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisCenteredZero": false,
            "axisLabel": "req/s",
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 10,
            "showPoints": "auto",
            "pointSize": 5
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "rate(propertyos_requests_total[5m])",
          "legendFormat": "{{method}} {{route}}",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Error Rate (errors/s)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed", "fixedColor": "red" },
          "custom": {
            "axisCenteredZero": false,
            "axisLabel": "errors/s",
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 10,
            "showPoints": "auto",
            "pointSize": 5
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "rate(propertyos_request_errors_total[5m])",
          "legendFormat": "{{method}} {{route}} {{status}}",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Avg Response Time (ms)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisCenteredZero": false,
            "axisLabel": "ms",
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 10,
            "showPoints": "auto",
            "pointSize": 5
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "propertyos_request_duration_avg_ms",
          "legendFormat": "{{method}} {{route}}",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Memory Usage",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisCenteredZero": false,
            "axisLabel": "bytes",
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 10,
            "showPoints": "auto",
            "pointSize": 5
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "propertyos_memory_rss_bytes",
          "legendFormat": "RSS",
          "refId": "A"
        },
        {
          "expr": "propertyos_memory_heap_used_bytes",
          "legendFormat": "Heap Used",
          "refId": "B"
        },
        {
          "expr": "propertyos_memory_heap_total_bytes",
          "legendFormat": "Heap Total",
          "refId": "C"
        },
        {
          "expr": "propertyos_memory_external_bytes",
          "legendFormat": "External",
          "refId": "D"
        }
      ]
    },
    {
      "title": "CPU Usage",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisCenteredZero": false,
            "axisLabel": "seconds",
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 10,
            "showPoints": "auto",
            "pointSize": 5
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "propertyos_cpu_user_seconds_total",
          "legendFormat": "User CPU",
          "refId": "A"
        },
        {
          "expr": "propertyos_cpu_system_seconds_total",
          "legendFormat": "System CPU",
          "refId": "B"
        }
      ]
    }
  ],
  "schemaVersion": 39,
  "tags": ["propertyos", "backend", "monitoring"],
  "templating": {
    "list": [
      {
        "current": {},
        "hide": 0,
        "includeAll": false,
        "label": "Datasource",
        "multi": false,
        "name": "datasource",
        "options": [],
        "query": "prometheus",
        "queryValue": "",
        "refresh": 1,
        "regex": "",
        "skipUrlSync": false,
        "type": "datasource"
      }
    ]
  },
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "timepicker": {},
  "timezone": "",
  "title": "PropertyOS Backend Dashboard",
  "uid": "propertyos-backend",
  "version": 1
}
