# Application
APP_NAME=IRED-PropertyOS
APP_PORT=4000
APP_ENV=development
APP_URL=http://localhost:4000
APP_FRONTEND_URL=http://localhost:3000

# Database
DATABASE_URL=postgresql://propertyos:propertyos@localhost:5432/propertyos?schema=public

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT Access Token
JWT_ACCESS_SECRET=change-me-in-production-access-secret-key
JWT_ACCESS_EXPIRY=15m

# JWT Refresh Token
JWT_REFRESH_SECRET=change-me-in-production-refresh-secret-key
JWT_REFRESH_EXPIRY=7d

# Email OTP
OTP_EXPIRY_MINUTES=10
OTP_MAX_ATTEMPTS=5
OTP_LENGTH=6

# SMTP (Email)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@propertyos.in

# S3 / Object Storage
S3_ENDPOINT=http://localhost:9000
S3_BUCKET=propertyos-media
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_REGION=us-east-1
S3_PUBLIC_URL=http://localhost:9000

# Throttler
THROTTLE_TTL=60000
THROTTLE_LIMIT=60

# SMS (console logs in dev, real provider in production)
SMS_PROVIDER=console
SMS_API_KEY=
SMS_API_SECRET=
SMS_SENDER_ID=IRED

# Push Notifications (console logs in dev, FCM in production)
PUSH_PROVIDER=console
PUSH_FCM_SERVER_KEY=

# Logging
LOG_LEVEL=debug

# CORS
CORS_ORIGIN=http://localhost:3000,http://127.0.0.1:3000,http://localhost:3100,http://127.0.0.1:3100

# Encryption (optional, AES-256-GCM for PII)
ENCRYPTION_KEY=
