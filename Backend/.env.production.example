# Environment variables for production deployment
# Copy to .env and fill in real values

# ─── Database ─────────────────────────────────────────────
DATABASE_URL=postgresql://propertyos:CHANGE_ME@localhost:5432/propertyos

# ─── Redis ────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ─── JWT ──────────────────────────────────────────────────
JWT_ACCESS_SECRET=CHANGE_ME_TO_A_SECURE_RANDOM_STRING_MIN_16_CHARS
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_SECRET=CHANGE_ME_TO_ANOTHER_SECURE_RANDOM_STRING_MIN_16_CHARS
JWT_REFRESH_EXPIRY=7d

# ─── App ──────────────────────────────────────────────────
APP_ENV=production
APP_NAME=IRED-PropertyOS
APP_PORT=3000
APP_URL=http://localhost:3000
APP_FRONTEND_URL=https://your-frontend-domain.com

# ─── CORS ────────────────────────────────────────────────
CORS_ORIGIN=https://your-domain.com

# ─── Throttler ───────────────────────────────────────────
THROTTLE_TTL=60000
THROTTLE_LIMIT=60

# ─── OTP ─────────────────────────────────────────────────
OTP_EXPIRY_MINUTES=10
OTP_MAX_ATTEMPTS=5
OTP_LENGTH=6

# ─── SMS (twilio | textlocal | console) ──────────────────
SMS_PROVIDER=console
SMS_API_KEY=
SMS_API_SECRET=
SMS_SENDER_ID=PROPERTYOS

# ─── Push Notifications (fcm | console) ──────────────────
PUSH_PROVIDER=console
PUSH_FCM_SERVER_KEY=

# ─── Email (SMTP) ───────────────────────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@propertyos.in

# ─── S3 / MinIO ──────────────────────────────────────────
S3_ENDPOINT=localhost
S3_BUCKET=propertyos-media
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_REGION=us-east-1
S3_PUBLIC_URL=http://localhost:9000

# ─── Encryption (optional, AES-256-GCM for PII) ─────────
ENCRYPTION_KEY=

# ─── Logging ─────────────────────────────────────────────
LOG_LEVEL=log
