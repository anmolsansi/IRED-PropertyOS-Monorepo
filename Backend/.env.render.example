# Render backend environment example
# Do not commit real values. Add these in Render dashboard or through render.yaml.

NODE_VERSION=20
NODE_ENV=production
APP_ENV=production
APP_NAME=IRED-PropertyOS
PORT=10000
APP_PORT=10000
APP_URL=https://ired-propertyos-api.onrender.com
APP_FRONTEND_URL=https://your-vercel-app.vercel.app
CORS_ORIGIN=https://your-vercel-app.vercel.app

# Neon Postgres
# For a simple Render web service, the direct Neon connection string is fine.
# Add sslmode=require and connect_timeout=15.
DATABASE_URL=postgresql://USER:PASSWORD@HOST.neon.tech/DB?sslmode=require&connect_timeout=15

# Auth and encryption
JWT_ACCESS_SECRET=generate-a-long-random-value
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_SECRET=generate-another-long-random-value
JWT_REFRESH_EXPIRY=7d
ENCRYPTION_KEY=generate-a-32-byte-random-value

# Redis is disabled for the free-tier setup.
# Add a real Redis or Valkey service later if queue-backed notifications are enabled.
REDIS_HOST=disabled
REDIS_PORT=6379
REDIS_PASSWORD=

# OTP
OTP_EXPIRY_MINUTES=10
OTP_MAX_ATTEMPTS=5
OTP_LENGTH=6

# Email option A: Gmail SMTP
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=yourapp.notifications@gmail.com
SMTP_PASS=your-google-app-password
SMTP_FROM=yourapp.notifications@gmail.com

# Email option B: Resend, use after domain verification
RESEND_API_KEY=
RESEND_FROM_EMAIL="IRED PropertyOS <otp@yourdomain.com>"

# Cloudflare R2
S3_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
S3_BUCKET=propertyos-media
S3_ACCESS_KEY=<r2-access-key-id>
S3_SECRET_KEY=<r2-secret-access-key>
S3_REGION=auto
S3_PUBLIC_URL=https://your-public-r2-domain-or-worker-url

# Admin seed, use only when running npm run db:seed manually
MASTER_ADMIN_EMAIL=admin@yourdomain.com
MASTER_ADMIN_PASSWORD=change-this-before-seeding

# Limits and logging
THROTTLE_TTL=60000
THROTTLE_LIMIT=60
LOG_LEVEL=log
SMS_PROVIDER=console
PUSH_PROVIDER=console
