# IRED PropertyOS monorepo local defaults

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:4000/api/v1
AUTH_SECRET=change-me-for-local-development
AUTH_URL=http://localhost:3000
NEXT_PUBLIC_GOOGLE_MAPS_KEY=

# Backend
APP_NAME=IRED-PropertyOS
APP_PORT=4000
APP_ENV=development
APP_URL=http://localhost:4000
APP_FRONTEND_URL=http://localhost:3000
CORS_ORIGIN=http://localhost:3000,http://127.0.0.1:3000,http://localhost:3100,http://127.0.0.1:3100

DATABASE_URL=postgresql://propertyos:propertyos@localhost:5432/propertyos?schema=public

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

JWT_ACCESS_SECRET=change-me-in-production-access-secret-key
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_SECRET=change-me-in-production-refresh-secret-key
JWT_REFRESH_EXPIRY=7d

OTP_EXPIRY_MINUTES=10
OTP_MAX_ATTEMPTS=5
OTP_LENGTH=6

RESEND_API_KEY=
RESEND_FROM_EMAIL="IRED PropertyOS <otp@yourdomain.com>"


MASTER_ADMIN_EMAIL=anmolsansi@gmail.com
MASTER_ADMIN_PASSWORD=change-me-before-running-seed

S3_ENDPOINT=http://localhost:9000
S3_BUCKET=propertyos-media
S3_ACCESS_KEY=change-me-local-access-key
S3_SECRET_KEY=change-me-local-secret-key
S3_REGION=us-east-1
S3_PUBLIC_URL=http://localhost:9000

THROTTLE_TTL=60000
THROTTLE_LIMIT=60

SMS_PROVIDER=console
SMS_API_KEY=
SMS_API_SECRET=
SMS_SENDER_ID=IRED

PUSH_PROVIDER=console
PUSH_FCM_SERVER_KEY=

LOG_LEVEL=debug
ENCRYPTION_KEY=
